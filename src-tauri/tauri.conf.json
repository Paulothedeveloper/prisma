{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PRISMA",
  "version": "0.9.68",
  "identifier": "com.paulo.prisma",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PRISMA",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 580,
        "decorations": false,
        "shadow": true,
        "additionalBrowserArgs": "--disable-features=msSmartScreenProtection,CalculateNativeWinOcclusion --disable-backgrounding-occluded-windows --disable-gpu-shader-disk-cache --disable-gpu-program-cache"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": ["binaries/*", "binaries/gyroflow/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installMode": "currentUser",
        "compression": "lzma",
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Paulothedeveloper/prisma/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzMUFGRTg5QjM2NEU3Q0UKUldUTzUyU3ppZjRhWTBheFY5YkxaRFZqQWt0NkJ6UFFLSkVGdW80cHIvUVB6NUNJTTNQbmIzdXUK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["prisma"]
      }
    }
  }
}
